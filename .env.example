# .env.example — VyaparAI Module 1
# Copy this file to .env and fill in your real keys
# NEVER commit .env — only commit this .env.example file

# Google Places API
# Get from: console.cloud.google.com → enable Places API → Credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic Claude API
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# --- FUTURE KEYS (V2 — do not add to .env until needed) ---
# WhatsApp Business API — apply at developers.facebook.com
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Petpooja POS API — apply at developer.petpooja.com
# PETPOOJA_API_KEY=
# PETPOOJA_API_SECRET=
